{
  "name": "ROS2 Humble Desktop Full",
  "image": "osrf/ros:humble-desktop-full",
  "remoteUser": "root",
  "containerUser": "root",
  "runArgs": [
    "--network=host",
    "-e", "DISPLAY=${DISPLAY}",
    "-v", "/tmp/.X11-unix:/tmp/.X11-unix:z",
    "-v", "/home/frank/.Xauthority:/root/.Xauthority:rw",
    "--cap-add=SYS_PTRACE",
    "--security-opt=seccomp=unconfined"
  ],
  "workspaceMount": "source=/home/frank/Projects/Robotics,target=/Workspace,type=bind,Z",
  "workspaceFolder": "/Workspace",
  "customizations": {
    "jetbrains": {
      "backend": "PyCharm"
    }
  },
  "remoteEnv": {
    "XAUTHORITY": "/root/.Xauthority",
    "ROS_DISTRO": "humble"
  },
  "postCreateCommand": "git config --global --add safe.directory /Workspace && echo 'source /opt/ros/humble/setup.bash' >> ~/.bashrc"
}
{
  "name": "ROS2 Humble Dev",
  "build": {
    "dockerfile": "Container"
  },
  "workspaceMount": "source=/home/frank/Projects/Robotics,target=/workspace,type=bind,Z",
  "workspaceFolder": "/workspace",
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt=seccomp=unconfined",
    "--security-opt=label=disable",
    "--userns=keep-id",
    "-e",
    "DISPLAY=${env:DISPLAY}",
    "-e",
    "XAUTHORITY=/tmp/.Xauthority",
    "-v",
    "/tmp/.X11-unix:/tmp/.X11-unix",
    "-v",
    "/home/frank/.Xauthority:/tmp/.Xauthority:ro"
  ],
  "remoteUser": "root",
  "containerUser": "root",
  "remoteEnv": {
    "HOME": "/workspace",
    "GIT_CONFIG_GLOBAL": "/workspace/.gitconfig"
  }
}
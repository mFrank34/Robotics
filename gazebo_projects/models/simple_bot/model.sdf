<sdf version="1.7">
    <model name="square_bot">
        <pose>0 0 0 0 0 0</pose>

        <link name="chassis">
            <pose relative_to='__model__'>0 0 0.15 0 0 0</pose>
            <inertial>
                <mass>1.5</mass>
                <inertia>
                    <ixx>0.1</ixx>
                    <iyy>0.1</iyy>
                    <izz>0.1</izz>
                </inertia>
            </inertial>

            <visual name="visual">
                <geometry>
                    <box>
                        <size>0.6 0.5 0.1</size>
                    </box>
                </geometry>
                <material>
                    <ambient>0 0 1 1</ambient>
                    <diffuse>0 0 1 1</diffuse>
                </material>
            </visual>

            <collision name="collision">
                <geometry>
                    <box>
                        <size>0.6 0.5 0.1</size>
                    </box>
                </geometry>
            </collision>
        </link>

        <!-- FRONT LIDAR  -->
        <link name="front_lidar_link">
            <pose relative_to="chassis">0.3 0 0.08 0 0 0</pose>
            <inertial>
                <mass>0.1</mass>
                <inertia>
                    <ixx>0.001</ixx>
                    <iyy>0.001</iyy>
                    <izz>0.001</izz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>0.04</radius>
                        <length>0.06</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.2 0.2 0.2 1</ambient>
                    <diffuse>0.2 0.2 0.2 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>0.04</radius>
                        <length>0.06</length>
                    </cylinder>
                </geometry>
            </collision>
            <sensor name="front_lidar" type="gpu_lidar">
                <pose>0 0 0 0 0 0</pose>
                <topic>front_lidar/scan</topic>
                <update_rate>10</update_rate>
                <lidar>
                    <scan>
                        <horizontal>
                            <samples>360</samples>
                            <resolution>1</resolution>
                            <min_angle>-1.5707963</min_angle>
                            <max_angle>1.5707963</max_angle>
                        </horizontal>
                    </scan>
                    <range>
                        <min>0.1</min>
                        <max>10.0</max>
                        <resolution>0.01</resolution>
                    </range>
                    <noise>
                        <type>gaussian</type>
                        <mean>0.0</mean>
                        <stddev>0.01</stddev>
                    </noise>
                </lidar>
                <visualize>true</visualize>
            </sensor>
        </link>

        <!--  BACK LIDAR  -->
        <link name="back_lidar_link">
            <pose relative_to="chassis">-0.3 0 0.08 0 0 3.1415927</pose>
            <inertial>
                <mass>0.1</mass>
                <inertia>
                    <ixx>0.001</ixx>
                    <iyy>0.001</iyy>
                    <izz>0.001</izz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>0.04</radius>
                        <length>0.06</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.2 0.2 0.2 1</ambient>
                    <diffuse>0.2 0.2 0.2 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>0.04</radius>
                        <length>0.06</length>
                    </cylinder>
                </geometry>
            </collision>
            <sensor name="back_lidar" type="gpu_lidar">
                <pose>0 0 0 0 0 0</pose>
                <topic>back_lidar/scan</topic>
                <update_rate>10</update_rate>
                <lidar>
                    <scan>
                        <horizontal>
                            <samples>360</samples>
                            <resolution>1</resolution>
                            <min_angle>-1.5707963</min_angle>
                            <max_angle>1.5707963</max_angle>
                        </horizontal>
                    </scan>
                    <range>
                        <min>0.1</min>
                        <max>10.0</max>
                        <resolution>0.01</resolution>
                    </range>
                    <noise>
                        <type>gaussian</type>
                        <mean>0.0</mean>
                        <stddev>0.01</stddev>
                    </noise>
                </lidar>
                <visualize>true</visualize>
            </sensor>
        </link>

        <!-- MOTORISED CAMERA -->
        <!-- Pan base: rotates left/right around Z axis -->
        <link name="camera_pan_link">
            <pose relative_to="chassis">0.28 0 0.1 0 0 0</pose>
            <inertial>
                <mass>0.05</mass>
                <inertia>
                    <ixx>0.0001</ixx>
                    <iyy>0.0001</iyy>
                    <izz>0.0001</izz>
                </inertia>
            </inertial>
            <!-- Grey cylinder as pan base -->
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>0.03</radius>
                        <length>0.04</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.5 0.5 0.5 1</ambient>
                    <diffuse>0.5 0.5 0.5 1</diffuse>
                </material>
            </visual>
        </link>

        <!-- Tilt head: rotates up/down around Y axis, holds the actual sensor -->
        <link name="camera_tilt_link">
            <pose relative_to="camera_pan_link">0 0 0.04 0 0 0</pose>
            <inertial>
                <mass>0.05</mass>
                <inertia>
                    <ixx>0.0001</ixx>
                    <iyy>0.0001</iyy>
                    <izz>0.0001</izz>
                </inertia>
            </inertial>
            <!-- Red box as camera body -->
            <visual name="visual">
                <geometry>
                    <box>
                        <size>0.05 0.08 0.05</size>
                    </box>
                </geometry>
                <material>
                    <ambient>0.8 0 0 1</ambient>
                    <diffuse>0.8 0 0 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <box>
                        <size>0.05 0.08 0.05</size>
                    </box>
                </geometry>
            </collision>

            <sensor name="front_camera" type="camera">
                <pose>0 0 0 0 0 0</pose>
                <topic>camera/image</topic>
                <update_rate>30</update_rate>
                <camera>
                    <horizontal_fov>1.047</horizontal_fov>
                    <image>
                        <width>640</width>
                        <height>480</height>
                        <format>R8G8B8</format>
                    </image>
                    <clip>
                        <near>0.1</near>
                        <far>20.0</far>
                    </clip>
                    <noise>
                        <type>gaussian</type>
                        <mean>0.0</mean>
                        <stddev>0.007</stddev>
                    </noise>
                </camera>
                <visualize>true</visualize>
            </sensor>
        </link>

        <!-- JOINTS  -->
        <joint name="front_lidar_joint" type="fixed">
            <parent>chassis</parent>
            <child>front_lidar_link</child>
        </joint>

        <joint name="back_lidar_joint" type="fixed">
            <parent>chassis</parent>
            <child>back_lidar_link</child>
        </joint>

        <!-- Pan joint: left/right +-90 degrees, independent of wheels -->
        <joint name="camera_pan_joint" type="revolute">
            <parent>chassis</parent>
            <child>camera_pan_link</child>
            <axis>
                <xyz expressed_in="__model__">0 0 1</xyz>
                <limit>
                    <lower>-1.5707963</lower>
                    <upper>1.5707963</upper>
                </limit>
            </axis>
        </joint>

        <!-- Tilt joint: up/down +-30 degrees, independent of wheels -->
        <joint name="camera_tilt_joint" type="revolute">
            <parent>camera_pan_link</parent>
            <child>camera_tilt_link</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
                <limit>
                    <lower>-0.5236</lower>
                    <upper>0.5236</upper>
                </limit>
            </axis>
        </joint>

        <!--  DRIVE WHEELS -->
        <link name="front_left_wheel">
            <pose relative_to="chassis">0.25 0.3 -0.05 0 0 0</pose>
            <inertial>
                <mass>0.3</mass>
                <inertia>
                    <ixx>0.01</ixx>
                    <iyy>0.01</iyy>
                    <izz>0.02</izz>
                </inertia>
            </inertial>
            <visual name="visual">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.1 0.1 0.1 1</ambient>
                    <diffuse>0.1 0.1 0.1 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>1.0</mu>
                            <mu2>1.0</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
        </link>

        <link name="front_right_wheel">
            <pose relative_to="chassis">0.25 -0.3 -0.05 0 0 0</pose>
            <inertial>
                <mass>0.3</mass>
                <inertia>
                    <ixx>0.01</ixx>
                    <iyy>0.01</iyy>
                    <izz>0.02</izz>
                </inertia>
            </inertial>
            <visual name="visual">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.1 0.1 0.1 1</ambient>
                    <diffuse>0.1 0.1 0.1 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>1.0</mu>
                            <mu2>1.0</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
        </link>

        <!-- REAR CASTER  -->
        <link name="rear_caster">
            <pose relative_to="chassis">-0.25 0 -0.05 0 0 0</pose>
            <inertial>
                <mass>0.1</mass>
                <inertia>
                    <ixx>0.001</ixx>
                    <iyy>0.001</iyy>
                    <izz>0.001</izz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <sphere>
                        <radius>0.1</radius>
                    </sphere>
                </geometry>
                <material>
                    <ambient>0.1 0.1 0.1 1</ambient>
                    <diffuse>0.1 0.1 0.1 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <sphere>
                        <radius>0.1</radius>
                    </sphere>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>0.0</mu>
                            <mu2>0.0</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
        </link>

        <joint name="front_left_joint" type="revolute">
            <parent>chassis</parent>
            <child>front_left_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
            </axis>
        </joint>

        <joint name="front_right_joint" type="revolute">
            <parent>chassis</parent>
            <child>front_right_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
            </axis>
        </joint>

        <joint name="rear_caster_joint" type="fixed">
            <parent>chassis</parent>
            <child>rear_caster</child>
        </joint>

        <!-- PLUGINS  -->

        <!-- Diff drive: controls wheels via /cmd_vel -->
        <plugin filename="libignition-gazebo-diff-drive-system.so"
                name="ignition::gazebo::systems::DiffDrive">
            <left_joint>front_left_joint</left_joint>
            <right_joint>front_right_joint</right_joint>
            <wheel_separation>0.6</wheel_separation>
            <wheel_radius>0.1</wheel_radius>
            <odom_publish_frequency>50</odom_publish_frequency>
            <topic>cmd_vel</topic>
        </plugin>

        <!-- Camera pan: independent of wheels, controlled via /camera_pan -->
        <plugin filename="libignition-gazebo-joint-position-controller-system.so"
                name="ignition::gazebo::systems::JointPositionController">
            <joint_name>camera_pan_joint</joint_name>
            <topic>camera_pan</topic>
            <p_gain>1.0</p_gain>
            <i_gain>0.0</i_gain>
            <d_gain>0.0</d_gain>
        </plugin>

        <!-- Camera tilt: independent of wheels, controlled via /camera_tilt -->
        <plugin filename="libignition-gazebo-joint-position-controller-system.so"
                name="ignition::gazebo::systems::JointPositionController">
            <joint_name>camera_tilt_joint</joint_name>
            <topic>camera_tilt</topic>
            <p_gain>1.0</p_gain>
            <i_gain>0.0</i_gain>
            <d_gain>0.0</d_gain>
        </plugin>

        <!-- Sensors: required for lidar and camera to work -->
        <plugin filename="libignition-gazebo-sensors-system.so"
                name="ignition::gazebo::systems::Sensors">
            <render_engine>ogre2</render_engine>
        </plugin>

    </model>
</sdf>
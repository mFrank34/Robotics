<?xml version="1.0" ?>
<sdf version="1.7">
    <model name="square_bot">
        <pose>0 0 0 0 0 0</pose>

        <link name="chassis">
            <!-- Arrow shaft — centered at x=0, sitting on top of chassis -->
            <visual name="arrow_shaft">
                <pose>0 0 0.06 0 0 0</pose>
                <geometry>
                    <box>
                        <size>0.25 0.03 0.03</size>
                    </box>
                </geometry>
                <material>
                    <ambient>1 1 0 1</ambient>
                    <diffuse>1 1 0 1</diffuse>
                </material>
            </visual>

            <!-- Arrow head — just ahead of shaft center, pointing forward -->
            <visual name="arrow_head">
                <pose>0.15 0 0.06 0 0 0</pose>
                <geometry>
                    <box>
                        <size>0.08 0.12 0.03</size>
                    </box>
                </geometry>
                <material>
                    <ambient>1 1 0 1</ambient>
                    <diffuse>1 1 0 1</diffuse>
                </material>
            </visual>

            <pose relative_to='__model__'>0 0 0.15 0 0 0</pose>
            <inertial>
                <mass>1.5</mass>
                <inertia>
                    <ixx>0.1</ixx>
                    <iyy>0.1</iyy>
                    <izz>0.1</izz>
                </inertia>
            </inertial>

            <visual name="visual">
                <geometry>
                    <box>
                        <size>0.6 0.5 0.1</size>
                    </box>
                </geometry>
                <material>
                    <ambient>0 0 1 1</ambient>
                    <diffuse>0 0 1 1</diffuse>
                </material>
            </visual>

            <collision name="collision">
                <geometry>
                    <box>
                        <size>0.6 0.5 0.1</size>
                    </box>
                </geometry>
            </collision>

        </link>

        <!-- ========== FRONT LIDAR ========== -->
        <link name="front_lidar_link">
            <!-- Sits on top front edge of chassis -->
            <pose relative_to="chassis">0.3 0 0.08 0 0 0</pose>
            <inertial>
                <mass>0.1</mass>
                <inertia>
                    <ixx>0.001</ixx>
                    <iyy>0.001</iyy>
                    <izz>0.001</izz>
                </inertia>
            </inertial>
            <!-- Small cylinder to visualise the sensor unit -->
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>0.04</radius>
                        <length>0.06</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.2 0.2 0.2 1</ambient>
                    <diffuse>0.2 0.2 0.2 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>0.04</radius>
                        <length>0.06</length>
                    </cylinder>
                </geometry>
            </collision>

            <sensor name="front_lidar" type="gpu_lidar">
                <pose>0 0 0 0 0 0</pose>
                <topic>front_lidar/scan</topic>
                <update_rate>10</update_rate>
                <lidar>
                    <scan>
                        <horizontal>
                            <!-- 180 degree forward-facing sweep -->
                            <samples>360</samples>
                            <resolution>1</resolution>
                            <min_angle>-1.5707963</min_angle>
                            <max_angle>1.5707963</max_angle>
                        </horizontal>
                    </scan>
                    <range>
                        <min>0.1</min>
                        <max>10.0</max>
                        <resolution>0.01</resolution>
                    </range>
                    <noise>
                        <type>gaussian</type>
                        <mean>0.0</mean>
                        <stddev>0.01</stddev>
                    </noise>
                </lidar>
                <visualize>true</visualize>
            </sensor>
        </link>

        <!-- ========== BACK LIDAR ========== -->
        <link name="back_lidar_link">
            <!-- Sits on top back edge of chassis, rotated 180deg to face rearward -->
            <pose relative_to="chassis">-0.3 0 0.08 0 0 3.1415927</pose>
            <inertial>
                <mass>0.1</mass>
                <inertia>
                    <ixx>0.001</ixx>
                    <iyy>0.001</iyy>
                    <izz>0.001</izz>
                </inertia>
            </inertial>
            <visual name="visual">
                <geometry>
                    <cylinder>
                        <radius>0.04</radius>
                        <length>0.06</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.2 0.2 0.2 1</ambient>
                    <diffuse>0.2 0.2 0.2 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <geometry>
                    <cylinder>
                        <radius>0.04</radius>
                        <length>0.06</length>
                    </cylinder>
                </geometry>
            </collision>

            <sensor name="back_lidar" type="gpu_lidar">
                <pose>0 0 0 0 0 0</pose>
                <topic>back_lidar/scan</topic>
                <update_rate>10</update_rate>
                <lidar>
                    <scan>
                        <horizontal>
                            <!-- 180 degree rear-facing sweep -->
                            <samples>360</samples>
                            <resolution>1</resolution>
                            <min_angle>-1.5707963</min_angle>
                            <max_angle>1.5707963</max_angle>
                        </horizontal>
                    </scan>
                    <range>
                        <min>0.1</min>
                        <max>10.0</max>
                        <resolution>0.01</resolution>
                    </range>
                    <noise>
                        <type>gaussian</type>
                        <mean>0.0</mean>
                        <stddev>0.01</stddev>
                    </noise>
                </lidar>
                <visualize>true</visualize>
            </sensor>
        </link>

        <!-- Lidar joints (fixed to chassis) -->
        <joint name="front_lidar_joint" type="fixed">
            <parent>chassis</parent>
            <child>front_lidar_link</child>
        </joint>

        <joint name="back_lidar_joint" type="fixed">
            <parent>chassis</parent>
            <child>back_lidar_link</child>
        </joint>

        <!-- ========== WHEELS (unchanged) ========== -->
        <link name="front_left_wheel">
            <pose relative_to="chassis">0.25 0.3 -0.05 0 0 0</pose>
            <inertial>
                <mass>0.3</mass>
                <inertia>
                    <ixx>0.01</ixx>
                    <iyy>0.01</iyy>
                    <izz>0.02</izz>
                </inertia>
            </inertial>
            <visual name="visual">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.1 0.1 0.1 1</ambient>
                    <diffuse>0.1 0.1 0.1 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>1.0</mu>
                            <mu2>1.0</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
        </link>

        <link name="front_right_wheel">
            <pose relative_to="chassis">0.25 -0.3 -0.05 0 0 0</pose>
            <inertial>
                <mass>0.3</mass>
                <inertia>
                    <ixx>0.01</ixx>
                    <iyy>0.01</iyy>
                    <izz>0.02</izz>
                </inertia>
            </inertial>
            <visual name="visual">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.1 0.1 0.1 1</ambient>
                    <diffuse>0.1 0.1 0.1 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>1.0</mu>
                            <mu2>1.0</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
        </link>

        <link name="rear_left_wheel">
            <pose relative_to="chassis">-0.25 0.3 -0.05 0 0 0</pose>
            <inertial>
                <mass>0.3</mass>
                <inertia>
                    <ixx>0.01</ixx>
                    <iyy>0.01</iyy>
                    <izz>0.02</izz>
                </inertia>
            </inertial>
            <visual name="visual">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.1 0.1 0.1 1</ambient>
                    <diffuse>0.1 0.1 0.1 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>1.0</mu>
                            <mu2>1.0</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
        </link>

        <link name="rear_right_wheel">
            <pose relative_to="chassis">-0.25 -0.3 -0.05 0 0 0</pose>
            <inertial>
                <mass>0.3</mass>
                <inertia>
                    <ixx>0.01</ixx>
                    <iyy>0.01</iyy>
                    <izz>0.02</izz>
                </inertia>
            </inertial>
            <visual name="visual">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <material>
                    <ambient>0.1 0.1 0.1 1</ambient>
                    <diffuse>0.1 0.1 0.1 1</diffuse>
                </material>
            </visual>
            <collision name="collision">
                <pose>0 0 0 1.5707963 0 0</pose>
                <geometry>
                    <cylinder>
                        <radius>0.1</radius>
                        <length>0.05</length>
                    </cylinder>
                </geometry>
                <surface>
                    <friction>
                        <ode>
                            <mu>1.0</mu>
                            <mu2>1.0</mu2>
                        </ode>
                    </friction>
                </surface>
            </collision>
        </link>

        <joint name="front_left_joint" type="revolute">
            <parent>chassis</parent>
            <child>front_left_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
            </axis>
        </joint>

        <joint name="front_right_joint" type="revolute">
            <parent>chassis</parent>
            <child>front_right_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
            </axis>
        </joint>

        <joint name="rear_left_joint" type="revolute">
            <parent>chassis</parent>
            <child>rear_left_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
            </axis>
        </joint>

        <joint name="rear_right_joint" type="revolute">
            <parent>chassis</parent>
            <child>rear_right_wheel</child>
            <axis>
                <xyz expressed_in="__model__">0 1 0</xyz>
            </axis>
        </joint>

        <!-- PLUGINS -->
        <plugin filename="libignition-gazebo-diff-drive-system.so"
                name="ignition::gazebo::systems::DiffDrive">
            <left_joint>front_left_joint</left_joint>
            <right_joint>front_right_joint</right_joint>
            <wheel_separation>0.6</wheel_separation>
            <wheel_radius>0.1</wheel_radius>
            <odom_publish_frequency>50</odom_publish_frequency>
            <topic>cmd_vel</topic>
        </plugin>

        <!-- Required for lidar sensors to work -->
        <plugin filename="libignition-gazebo-sensors-system.so"
                name="ignition::gazebo::systems::Sensors">
            <render_engine>ogre2</render_engine>
        </plugin>

    </model>
</sdf>